{
  "expo": {
    "name": "The ID Game",
    "slug": "id-game",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "id-game",
    "platforms": ["ios", "android", "web"],
    "newArchEnabled": true,
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#FAF7F0"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F0"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
